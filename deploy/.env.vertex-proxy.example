# Vertex AI proxy bootstrap values.
# Usage:
#   cp deploy/.env.vertex-proxy.example deploy/.env.vertex-proxy
#   docker compose -f deploy/docker-compose.vertex-proxy.yml --env-file deploy/.env.vertex-proxy up -d

VERTEX_PROXY_IMAGE=ghcr.io/prantlf/ovai:latest
VERTEX_PROXY_BIND=127.0.0.1
VERTEX_PROXY_PORT=22434
VERTEX_PROXY_INTERNAL_PORT=22434
VERTEX_PROXY_DEBUG=ovai:srv
VERTEX_PROXY_DOCKER_NETWORK=sentinel-ai

# Absolute path on the server to the Google service account JSON used for Vertex AI.
VERTEX_PROXY_GOOGLE_ACCOUNT_FILE=/home/sentinel/sentinel/deploy/google-account.json
