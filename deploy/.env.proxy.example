# Shared autodiscovery Caddy bootstrap values.
# Run once per host or locally for development:
#   cp deploy/.env.proxy.example deploy/.env.proxy
#   docker compose -f deploy/docker-compose.proxy.yml --env-file deploy/.env.proxy up -d

CADDY_IMAGE=lucaslorentz/caddy-docker-proxy:2.11-alpine
CADDY_EMAIL=admin@example.com
CADDY_INGRESS_NETWORKS=shared-proxy
TZ=Europe/Prague
