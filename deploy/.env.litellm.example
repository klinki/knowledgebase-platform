# LiteLLM Vertex AI proxy bootstrap values.
# Usage:
#   cp deploy/.env.litellm.example deploy/.env.litellm
#   docker compose -f deploy/docker-compose.litellm.yml --env-file deploy/.env.litellm up -d

LITELLM_IMAGE=docker.litellm.ai/berriai/litellm:main-latest
LITELLM_BIND=127.0.0.1
LITELLM_PORT=4000
LITELLM_INTERNAL_PORT=4000
LITELLM_DOCKER_NETWORK=sentinel-ai

# The Google Cloud project LiteLLM should use for Vertex AI calls.
LITELLM_VERTEX_PROJECT=your-gcp-project-id
LITELLM_VERTEX_LOCATION=us-central1

# Absolute path on the server to the Google service account JSON used for Vertex AI.
LITELLM_GOOGLE_ACCOUNT_FILE=/home/sentinel/sentinel/deploy/google-account.json

# Optional. Leave empty if the proxy is only bound locally and used internally.
# If you set this, Sentinel's OPENAI_API_KEY must match.
LITELLM_MASTER_KEY=
