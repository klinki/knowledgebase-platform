# Container registry
REGISTRY=ghcr.io
REGISTRY_USERNAME=your-registry-user
REGISTRY_PASSWORD=your-registry-token
IMAGE_NAMESPACE=your-org-or-user

# Application secrets and runtime configuration
SENTINEL_DOMAIN=sentinel.example.com
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this
POSTGRES_DB=sentinel_knowledgebase
AUTHENTICATION_JWT_SIGNING_KEY=replace-with-a-long-random-secret
AUTHENTICATION_FRONTEND_URL=https://sentinel.example.com
OPENAI_API_KEY=change-this
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDINGS_URL=https://api.openai.com/v1/embeddings
OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
